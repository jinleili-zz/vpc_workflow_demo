{
  "name": "NSP Top API with JWT",
  "slug": "nsp-top-api-jwt",
  "api_id": "nsp-top-api-jwt-v1",
  "org_id": "nsp-org",
  "use_keyless": false,
  "use_standard_auth": false,
  "enable_jwt": true,
  "jwt_signing_method": "hmac",
  "jwt_source": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9",
  "jwt_identity_base_field": "sub",
  "jwt_policy_field_name": "pol",
  "jwt_default_policies": ["default"],
  "auth": {
    "auth_header_name": "Authorization"
  },
  "definition": {
    "location": "header",
    "key": "x-api-version"
  },
  "version_data": {
    "not_versioned": true,
    "versions": {
      "Default": {
        "name": "Default",
        "use_extended_paths": true,
        "extended_paths": {
          "ignored": [],
          "white_list": [],
          "black_list": []
        }
      }
    }
  },
  "proxy": {
    "listen_path": "/jwt/",
    "target_url": "http://top-nsp:8080",
    "strip_listen_path": true,
    "enable_load_balancing": false,
    "check_host_against_uptime_tests": false,
    "preserve_host_header": false
  },
  "enable_batch_request_support": false,
  "enable_ip_whitelisting": false,
  "enable_ip_blacklisting": false,
  "enable_context_vars": false,
  "do_not_track": false,
  "tags": ["nsp", "jwt"],
  "active": true,
  "internal": false
}
