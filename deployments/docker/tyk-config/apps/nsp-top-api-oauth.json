{
  "name": "NSP Top API with OAuth",
  "slug": "nsp-top-api-oauth",
  "api_id": "nsp-top-api-oauth-v1",
  "org_id": "nsp-org",
  "use_keyless": false,
  "use_oauth2": true,
  "oauth_meta": {
    "allowed_access_types": [
      "authorization_code",
      "refresh_token",
      "client_credentials"
    ],
    "allowed_authorize_types": [
      "code",
      "token"
    ],
    "auth_login_redirect": "http://localhost:9696/oauth/authorize/"
  },
  "auth": {
    "auth_header_name": "Authorization"
  },
  "definition": {
    "location": "header",
    "key": "x-api-version"
  },
  "version_data": {
    "not_versioned": true,
    "versions": {
      "Default": {
        "name": "Default",
        "use_extended_paths": true,
        "extended_paths": {}
      }
    }
  },
  "proxy": {
    "listen_path": "/oauth/",
    "target_url": "http://top-nsp:8080",
    "strip_listen_path": true,
    "enable_load_balancing": false
  },
  "tags": ["nsp", "oauth"],
  "active": true
}
